# Django settings
DEBUG=False
SECRET_KEY=your-secret-key-here-generate-a-random-one
ALLOWED_HOSTS=.onrender.com,.vercel.app,localhost,127.0.0.1
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False

# Database (Render provides this)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# For local development without DATABASE_URL, SQLite will be used

# ============================================================================
# EMAIL INTEGRATION - SendGrid (Primary)
# ============================================================================
# Use SendGrid to avoid conflicts with other applications using same SMTP
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
# Get API Key from: https://app.sendgrid.com/settings/api_keys

# ============================================================================
# WhatsApp/SMS INTEGRATION - Twilio
# ============================================================================
# Use separate Twilio account to isolate from other applications
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+15551234567
TWILIO_PHONE_FROM=+15551234567
TWILIO_OWNER_WHATSAPP_TO=whatsapp:+2547XXXXXXXX
TWILIO_WHATSAPP_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Get credentials from: https://console.twilio.com
# Example: whatsapp:+1234567890 format

# ============================================================================
# reCAPTCHA
# ============================================================================
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# ============================================================================
# Slack notifications (optional)
# ============================================================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================================================
# Frontend Configuration (update in config/env.js instead)
# ============================================================================
# This is the backend URL that the frontend will call
API_BASE=https://your-render-backend-url.onrender.com
